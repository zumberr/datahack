# Database (puerto 5433 para evitar conflicto con Postgres local — ver docker-compose.yml)
DATABASE_URL=postgresql+psycopg://bravobot:bravobot@localhost:5433/bravobot

# LLM providers (set the ones you have; at least one is required)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Provider preference order (comma-separated)
LLM_PROVIDER_ORDER=groq,cerebras,anthropic

# Embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024

# Retrieval
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES=10

# Confidence gate thresholds
CONFIDENCE_TOP1_MIN=0.32
CONFIDENCE_TOP3_MEAN_MIN=0.28
CONFIDENCE_CONSISTENCY_MIN=0.5
CONFIDENCE_KEYWORD_COVERAGE_MIN=0.4
CONFIDENCE_SIGNALS_REQUIRED=3
CONFIDENCE_CATASTROPHIC_MIN=0.20

# Session
SESSION_HISTORY_TURNS=6

# Server
CORS_ORIGINS=*
LOG_LEVEL=INFO

# --- Despliegue en Hugging Face Spaces + Supabase ---
# HF Spaces usa el Dockerfile de la raíz y fija PORT=7860.
# Configura estas claves como Secrets del Space (Settings → Variables and secrets).
#
# DATABASE_URL debe apuntar a tu proyecto Supabase (pgvector activado previamente
# en Database → Extensions). Usa el **Session pooler** (puerto 5432, soporta
# prepared statements de SQLAlchemy). Formato:
#
#   DATABASE_URL=postgresql+psycopg://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require
#
# Evita el Transaction pooler (puerto 6543): rompe SQLAlchemy.
# La Direct connection (db.<PROJECT_REF>.supabase.co:5432) también funciona
# si tu red tiene IPv6.
#
# Opciones del entrypoint (scripts/hf_spaces_entrypoint.sh):
# INIT_DB_ON_START=true            # aplica scripts/init_db.sql al arrancar (default true)
# INGEST_ON_START=false            # si true, corre ingest al arrancar (default false)
# INGEST_PATH=scripts/sample_data  # ruta con los JSON dentro del contenedor
